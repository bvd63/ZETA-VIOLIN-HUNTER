# ============================================================
# Zeta Violin Hunter — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- TELEGRAM (required) ---
# 1. Message @BotFather on Telegram → /newbot → copy token
TELEGRAM_BOT_TOKEN=

# 2. Message @userinfobot on Telegram → copy your chat ID
TELEGRAM_CHAT_ID=

# --- EBAY API (free — get at developer.ebay.com) ---
EBAY_APP_ID=

# --- GOOGLE CUSTOM SEARCH (free: 100 queries/day) ---
# 1. Get API key: https://console.cloud.google.com → Custom Search API
# 2. Create engine: https://programmablesearchengine.google.com → Search entire web
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# --- SCHEDULE ---
# Hour (UTC) to run daily search. 9 = 09:00 UTC = 12:00 Romania
SEARCH_HOUR=9

# --- YEAR FILTER ---
# Caută viori fabricate între acești ani
MIN_YEAR=1980
MAX_YEAR=2014

# --- PRICE FILTER (optional) ---
MIN_PRICE=0
MAX_PRICE=99999

# --- CONDITION FILTER ---
# Options: all, new, used
CONDITION=all

# --- RUNTIME HARDENING ---
# Max time per scraper (seconds)
SCRAPER_TIMEOUT_SEC=3600
# Retries for temporary failures/timeouts
SCRAPER_RETRIES=3
# How many scrapers run in parallel
SCRAPER_CONCURRENCY=4

# --- CRAIGSLIST TUNING ---
# Internal concurrency for Craigslist city crawling (10-40 recommended)
CRAIGSLIST_CONCURRENCY=16
# Upper cap for US cities crawled per cycle (0 = all discovered cities)
CRAIGSLIST_MAX_US_CITIES=0
