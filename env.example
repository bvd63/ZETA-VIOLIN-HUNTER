# ============================================================
# Zeta Violin Hunter — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- TELEGRAM (required) ---
# 1. Message @BotFather on Telegram → /newbot → copy token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 2. Message @userinfobot on Telegram → copy your chat ID
TELEGRAM_CHAT_ID=your_chat_id_here

# --- EBAY API (free — get at developer.ebay.com) ---
EBAY_APP_ID=your_ebay_app_id_here

# --- GOOGLE CUSTOM SEARCH (free: 100 queries/day) ---
# 1. Get API key: https://console.cloud.google.com → Custom Search API
# 2. Create engine: https://programmablesearchengine.google.com → Search entire web
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_cse_id_here

# --- SCHEDULE ---
# Hour (UTC) to run daily search. 9 = 09:00 UTC = 12:00 Romania
SEARCH_HOUR=9

# --- YEAR FILTER ---
# Caută viori fabricate între acești ani
MIN_YEAR=1980
MAX_YEAR=2014

# --- PRICE FILTER (optional) ---
MIN_PRICE=0
MAX_PRICE=99999

# --- CONDITION FILTER ---
# Options: all, new, used
CONDITION=all
